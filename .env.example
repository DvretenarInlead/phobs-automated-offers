# --- App ---
NODE_ENV=development
PORT=8080
PUBLIC_BASE_URL=http://localhost:8080
LOG_LEVEL=debug

# --- Crypto ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_VAULT_KEY=
# Optional second key during rotation
TOKEN_VAULT_KEY_PREV=

# Session signing (admin UI). 32+ bytes base64.
SESSION_SECRET=

# --- HubSpot Public App ---
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_APP_ID=
HUBSPOT_REDIRECT_URI=http://localhost:8080/oauth/callback
HUBSPOT_SCOPES=crm.objects.deals.read crm.objects.deals.write crm.objects.line_items.read crm.objects.line_items.write crm.objects.quotes.read crm.objects.quotes.write crm.objects.products.read crm.objects.products.write hubdb
# JWKS URL for verifying HubSpot Workflow Extension JWTs. Override if your
# HubSpot account region uses a different endpoint.
HUBSPOT_JWKS_URL=https://api.hubapi.com/.well-known/jwks.json

# --- Infra ---
DATABASE_URL=postgres://phobs:phobs@localhost:5432/phobs
REDIS_URL=redis://localhost:6379

# --- Admin ---
ADMIN_IP_ALLOWLIST=

# --- Observability ---
# Token-gate the /metrics endpoint. If unset in production, /metrics is
# restricted to localhost only.
METRICS_TOKEN=

# OpenTelemetry tracing (off by default). Set to your OTLP/HTTP collector to
# enable; e.g. https://otlp.honeycomb.io or http://localhost:4318
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=phobs-automated-offers
