{
  "name": "phobs-automated-offers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:web": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "dev:ui": "vite",
    "build": "npm run build:server && npm run build:ui",
    "build:server": "tsc -p tsconfig.build.json",
    "build:ui": "vite build",
    "start:web": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc -p web/tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "admin:create": "tsx src/cli/createAdmin.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/helmet": "^13.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/static": "^8.0.4",
    "@hubspot/api-client": "^12.0.1",
    "argon2": "^0.41.1",
    "bullmq": "^5.34.0",
    "drizzle-orm": "^0.36.4",
    "fast-xml-parser": "^4.5.1",
    "fastify": "^5.2.0",
    "fastify-raw-body": "^5.0.0",
    "ioredis": "^5.4.1",
    "jose": "^5.9.6",
    "otpauth": "^9.3.6",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "prom-client": "^15.1.3",
    "undici": "^7.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tanstack/react-query": "^5.62.7",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.17.0",
    "eslint-plugin-security": "^3.0.1",
    "pino-pretty": "^13.0.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
